{
  "name": "baileys-native-performance-fork",
  "type": "module",
  "version": "7.0.0-rc.9",
  "description": "Baileys fork with a native C++ engine focused on performance, security, and low latency",
  "keywords": [
    "whatsapp",
    "automation"
  ],
  "homepage": "https://github.com/unknownncat/Baileys/",
  "repository": {
    "url": "git@github.com:unknownncat/Baileys.git"
  },
  "license": "MIT",
  "author": "unknownncat",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "WAProto/**/*",
    "engine-requirements.js",
    "binding.gyp",
    "native/**/*.c",
    "native/**/*.cc",
    "native/**/*.cpp",
    "native/**/*.h",
    "native/**/*.inc",
    "native/**/*.json",
    "native/**/*.proto",
    "native/**/*.sha256",
    "scripts/postinstall-native-build.mjs",
    "scripts/verify-native-deps.mjs",
    "scripts/native-protobuf-gyp.cjs"
  ],
  "scripts": {
    "build:all": "npm run build && npm run build:docs",
    "build:docs": "typedoc",
    "build:native": "node ./scripts/generate-waproto-cpp.mjs && node ./scripts/verify-native-deps.mjs && node-gyp rebuild -j max",
    "build:native:install": "node ./scripts/postinstall-native-build.mjs",
    "build:native:debug": "node ./scripts/generate-waproto-cpp.mjs && node ./scripts/verify-native-deps.mjs && node-gyp rebuild --debug -j max",
    "benchmark:native": "node ./scripts/benchmark-native-hotpaths.mjs",
    "benchmark:media": "node --import tsx ./scripts/benchmark-media-hotpaths.ts",
    "benchmark:signal": "node --import tsx ./scripts/benchmark-signal-hotpaths.ts",
    "build": "tsc -P tsconfig.build.json && tsc-esm-fix --tsconfig=tsconfig.build.json --ext=.js",
    "changelog:last": "conventional-changelog -p angular -r 2",
    "changelog:preview": "conventional-changelog -p angular -u",
    "changelog:update": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "example": "tsx ./Example/example.ts",
    "gen:protobuf": "sh WAProto/GenerateStatics.sh",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "lint": "tsc && eslint src --ext .js,.ts",
    "lint:fix": "npm run format && npm run lint -- --fix",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "preinstall": "node ./engine-requirements.js",
    "postinstall": "node ./scripts/postinstall-native-build.mjs",
    "test:native": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js src/__tests__/Native --runInBand",
    "verify:native-deps": "node ./scripts/verify-native-deps.mjs",
    "release": "release-it",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testMatch '**/*.test.ts'",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testMatch '**/*.test-e2e.ts'",
    "update:version": "tsx ./scripts/update-version.ts"
  },
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "async-mutex": "^0.5.0",
    "libsignal": "https://github.com/unknownncat/libsignal-node.git#commit=cd946a3752030b73f2bf2811ab634e97ebda555d",
    "lru-cache": "^11.1.0",
    "music-metadata": "^11.7.0",
    "node-addon-api": "^8.6.0",
    "p-queue": "^9.0.0",
    "pino": "^9.6",
    "protobufjs": "^7.2.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-rust-bridge": "0.5.2",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.9.0",
    "@types/qrcode-terminal": "^0",
    "@types/ws": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@whiskeysockets/eslint-config": "^1.0.0",
    "conventional-changelog": "^7.1.1",
    "conventional-changelog-angular": "^8.0.0",
    "esbuild": "^0.27.3",
    "esbuild-register": "^3.6.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.4.0",
    "jest": "^30.0.5",
    "jimp": "^1.6.0",
    "jiti": "^2.4.2",
    "json": "^11.0.0",
    "link-preview-js": "^3.0.0",
    "lru-cache": "^11.1.0",
    "node-gyp": "^12.2.0",
    "open": "^8.4.2",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.5.3",
    "protobufjs-cli": "^1.1.3",
    "release-it": "^15.10.3",
    "ts-jest": "^29.4.0",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.20.3",
    "typedoc": "^0.27.9",
    "typedoc-plugin-markdown": "4.4.2",
    "typescript": "~5.8.2"
  },
  "peerDependencies": {
    "audio-decode": "^2.1.3",
    "jimp": "^1.6.0",
    "link-preview-js": "^3.0.0",
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "audio-decode": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
